<base:PageBase x:Class="Audio.AudioDeviceRebootTest"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Audio"
             xmlns:base="clr-namespace:Base.Pages;assembly=Base"
             xmlns:components="clr-namespace:Base.Components;assembly=Base"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:Background="White">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ComboBox x:Name="SourceDeviceADropdown" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        <ComboBox x:Name="SourceDeviceBDropdown" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

        <TextBlock Text="Cycle Time" Grid.Row="2" Grid.Column="0" Margin="2" VerticalAlignment="Center"/>
        <ui:NumberBox x:Name="CycleTimeInputField" Grid.Row="2" Grid.Column="2" MinWidth="120" Text="1000" Margin="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

        <TextBlock Text="Retry Count" Grid.Row="3" Grid.Column="0" Margin="2" VerticalAlignment="Center"/>
        <ui:NumberBox x:Name="RetryInputField" Grid.Row="3" Grid.Column="2" MinWidth="120" Text="5" Margin="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

        <TextBlock Text="Retry Interval (ms)" Grid.Row="4" Grid.Column="0" Margin="2" VerticalAlignment="Center"/>
        <ui:NumberBox x:Name="RetryIntervalInputField" Grid.Row="4" Grid.Column="2" MinWidth="120" Text="1000" Margin="2" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

        <Button x:Name="StartTestButton" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Content="Start Test" Margin="2" Height="40" HorizontalAlignment="Stretch" VerticalAlignment="Center" Click="StartTest_Click"/>
        <Button x:Name="StopTestButton" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Content="Stop Test" Margin="2" Height="40" HorizontalAlignment="Stretch" VerticalAlignment="Center" Click="StopTest_Click" Visibility="Collapsed"/>

        <TextBlock x:Name="RetryTextBlock" Text="Retrying... 0/3" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed"/>
        <TextBlock x:Name="ProgressTextBlock" Text="0/1000" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed"/>

    </Grid>
</base:PageBase>
