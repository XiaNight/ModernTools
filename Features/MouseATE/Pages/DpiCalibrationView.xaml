<UserControl x:Class="MouseATE.Pages.DpiCalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="820" d:DesignWidth="960"
             FontFamily="Consolas"
             Padding="16"
             Loaded="UserControl_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical">

            <!-- ── Pipeline Setup ─────────────────────────────────── -->
            <GroupBox Header="Pipeline Setup" Margin="0 0 0 12">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto" MinWidth="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Device Profile:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <ComboBox x:Name="ProfileCombo" Grid.Row="0" Grid.Column="1"
                              SelectionChanged="ProfileCombo_SelectionChanged" Margin="4 4 0 4"/>

                    <TextBlock Text="Serial Number:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <TextBox x:Name="SerialNumberBox" Grid.Row="1" Grid.Column="1"
                             Text="" Margin="4 4 0 4" ToolTip="Optional — written into the report"/>

                    <TextBlock Text="Output Folder:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <TextBox x:Name="OutputFolderBox" Grid.Row="2" Grid.Column="1"
                             Text="" Margin="4 4 0 4"/>
                    <Button x:Name="BrowseBtn" Content="Browse..." Grid.Row="2" Grid.Column="1"
                            Width="80" HorizontalAlignment="Right" Click="BrowseBtn_Click" Margin="4 4 0 4"/>

                    <!-- Right column: test parameters -->
                    <TextBlock Text="Calibration DPI:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                    <TextBox x:Name="CalDpiBox" Grid.Row="0" Grid.Column="4" IsReadOnly="True"
                             Margin="4 4 0 4" Opacity="0.8"/>

                    <TextBlock Text="Z Offset (mm):" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                    <TextBox x:Name="ZOffsetBox" Grid.Row="1" Grid.Column="4" Text="2.5" Margin="4 4 0 4"/>

                    <TextBlock Text="Cycles:" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                    <TextBox x:Name="CyclesBox" Grid.Row="2" Grid.Column="4" Text="5" Margin="4 4 0 4"/>
                </Grid>
            </GroupBox>

            <!-- ── Automated Pipelines ────────────────────────────── -->
            <GroupBox Header="Automated Pipelines" Margin="0 0 0 12">
                <StackPanel Margin="8">
                    <TextBlock TextWrapping="Wrap" Margin="0 0 0 8" Opacity="0.7" FontSize="11">
                        ReCalibration: clear existing cal → measure sensor DPI → write new cal → verify.
                        CheckCalibration: measure with current cal → clear → measure sensor raw → restore cal → report.
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                        <Button x:Name="ReCalBtn" Content="▶ ReCalibration" Width="170"
                                Click="ReCalBtn_Click" Margin="0 0 12 0"/>
                        <Button x:Name="CheckCalBtn" Content="▶ CheckCalibration" Width="180"
                                Click="CheckCalBtn_Click" Margin="0 0 16 0"/>
                        <Button x:Name="PipelineCancelBtn" Content="■ Cancel" Width="100"
                                Click="PipelineCancel_Click" IsEnabled="False" Margin="0 0 16 0"/>
                        <TextBlock x:Name="PipelineStatus" Text="" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>

                    <!-- Pipeline step progress -->
                    <ProgressBar x:Name="PipelineProgress" Height="8" Minimum="0" Maximum="100" Value="0"
                                 Margin="0 0 0 8"/>

                    <!-- Pipeline step list -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1" Margin="0 0 0 4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="Step1Icon" Text="○" Grid.Row="0" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step1Text" Text="Enable factory mode" Grid.Row="0" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="Step2Icon" Text="○" Grid.Row="1" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step2Text" Text="Read / save current calibration" Grid.Row="1" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="Step3Icon" Text="○" Grid.Row="2" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step3Text" Text="Clear calibration" Grid.Row="2" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="Step4Icon" Text="○" Grid.Row="3" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step4Text" Text="Measure sensor DPI (X axis)" Grid.Row="3" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="Step5Icon" Text="○" Grid.Row="4" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step5Text" Text="Measure sensor DPI (Y axis)" Grid.Row="4" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="Step6Icon" Text="○" Grid.Row="5" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step6Text" Text="Write / verify calibration" Grid.Row="5" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="Step7Icon" Text="○" Grid.Row="6" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step7Text" Text="Verify DPI after calibration" Grid.Row="6" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="Step8Icon" Text="○" Grid.Row="7" Grid.Column="0" Margin="2 2 4 2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Step8Text" Text="Disable factory mode" Grid.Row="7" Grid.Column="1" Margin="0 2" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </GroupBox>

            <!-- ── Pipeline Results ───────────────────────────────── -->
            <GroupBox Header="Pipeline Results" Margin="0 0 0 12">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="200"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto" MinWidth="200"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="X Sensor (before cal):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0 4" FontWeight="Bold"/>
                    <TextBlock x:Name="XOrigText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="4 4 0 4"/>

                    <TextBlock Text="Y Sensor (before cal):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0 4" FontWeight="Bold"/>
                    <TextBlock x:Name="YOrigText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="4 4 0 4"/>

                    <TextBlock Text="X After calibration:" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4" FontWeight="Bold"/>
                    <TextBlock x:Name="XAfterText" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Margin="4 4 0 4"/>

                    <TextBlock Text="Y After calibration:" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4" FontWeight="Bold"/>
                    <TextBlock x:Name="YAfterText" Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Margin="4 4 0 4"/>

                    <TextBlock Text="New Cal X (hex):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <TextBlock x:Name="NewCalXText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="4 4 0 4"/>

                    <TextBlock Text="New Cal Y (hex):" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                    <TextBlock x:Name="NewCalYText" Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Margin="4 4 0 4"/>

                    <TextBlock x:Name="OverallResultText" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5"
                               FontSize="16" FontWeight="Bold" Margin="0 8 0 0"/>

                    <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Margin="0 8 0 0">
                        <Button x:Name="ExportCsvBtn" Content="Export CSV" Width="120"
                                Click="ExportCsv_Click" IsEnabled="False" Margin="0 0 8 0"/>
                        <Button x:Name="ExportXlsxBtn" Content="Export XLSX" Width="120"
                                Click="ExportXlsx_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- ── Manual Commands ────────────────────────────────── -->
            <GroupBox Header="Manual Device Commands" Margin="0 0 0 12">
                <StackPanel Margin="8">
                    <TextBlock Text="Direct HID commands — use for troubleshooting. Factory mode must be enabled first."
                               Margin="0 0 0 8" Opacity="0.7" FontSize="11"/>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                        <Button x:Name="EnableFactoryModeBtn" Content="Enable Factory" Width="160"
                                Click="EnableFactoryMode_Click" Margin="0 0 8 0"/>
                        <Button x:Name="DisableFactoryModeBtn" Content="Disable Factory" Width="160"
                                Click="DisableFactoryMode_Click" Margin="0 0 16 0"/>
                        <TextBlock x:Name="FactoryModeStatus" Text="" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                        <Button x:Name="ReadCalBtn" Content="Read Calibration" Width="160"
                                Click="ReadCal_Click" Margin="0 0 8 0"/>
                        <Button x:Name="ClearCalBtn" Content="Clear Calibration" Width="160"
                                Click="ClearCal_Click"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="140"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto" MinWidth="140"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="DPI Level:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox x:Name="ReadDpiLevelBox" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Margin="4 4 0 4" Opacity="0.8"/>

                        <TextBlock Text="X Cal:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox x:Name="ReadXCalBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="4 4 0 4" Opacity="0.8"/>

                        <TextBlock Text="Y Cal:" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                        <TextBox x:Name="ReadYCalBox" Grid.Row="1" Grid.Column="4" IsReadOnly="True" Margin="4 4 0 4" Opacity="0.8"/>

                        <TextBlock Text="New X Cal:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                        <TextBox x:Name="WriteXCalBox" Grid.Row="2" Grid.Column="1" Text="0" Margin="4 4 0 4"/>

                        <TextBlock Text="New Y Cal:" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                        <TextBox x:Name="WriteYCalBox" Grid.Row="2" Grid.Column="4" Text="0" Margin="4 4 0 4"/>

                        <Button x:Name="WriteCalBtn" Content="Write Calibration" Width="160"
                                Grid.Row="2" Grid.Column="5"
                                HorizontalAlignment="Left" Click="WriteCal_Click" Margin="8 4 0 4"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
