<UserControl x:Class="MouseATE.Pages.DpiTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="820" d:DesignWidth="960"
             FontFamily="Consolas"
             Padding="16"
             Loaded="UserControl_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical">

            <!-- ── Test Setup ─────────────────────────────────────────── -->
            <GroupBox Header="Test Setup" Margin="0 0 0 12">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Device Profile -->
                    <TextBlock Text="Device Profile:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <ComboBox x:Name="ProfileCombo" Grid.Row="0" Grid.Column="1"
                              SelectionChanged="ProfileCombo_SelectionChanged" Margin="4 4 0 4"/>

                    <!-- Axis selection -->
                    <TextBlock Text="Axis:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Margin="4 4 0 4">
                        <RadioButton x:Name="AxisX"  Content="X"  GroupName="Axis" IsChecked="True" Margin="0 0 12 0"/>
                        <RadioButton x:Name="AxisY"  Content="Y"  GroupName="Axis" Margin="0 0 12 0"/>
                        <RadioButton x:Name="AxisXY" Content="XY (Both)" GroupName="Axis"/>
                    </StackPanel>

                    <!-- Test mode -->
                    <TextBlock Text="Test Mode:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Margin="4 4 0 4">
                        <RadioButton x:Name="ModeSingle" Content="Single Test" GroupName="Mode"
                                     IsChecked="True" Checked="Mode_Checked" Margin="0 0 12 0"/>
                        <RadioButton x:Name="ModeMediaReview" Content="Media Review" GroupName="Mode"
                                     Checked="Mode_Checked" Margin="0 0 12 0"/>
                        <RadioButton x:Name="ModeFullTest" Content="Full Test" GroupName="Mode"
                                     Checked="Mode_Checked"/>
                    </StackPanel>

                    <!-- Single DPI entry (visible when ModeSingle) -->
                    <TextBlock x:Name="SingleDpiLabel" Text="Target DPI:" Grid.Row="3" Grid.Column="0"
                               VerticalAlignment="Center" Margin="0 4"/>
                    <TextBox x:Name="SingleDpiBox" Grid.Row="3" Grid.Column="1"
                             Text="1600" Margin="4 4 0 4"/>

                    <!-- Media Review DPI list (visible when ModeMediaReview) -->
                    <TextBlock x:Name="MrDpiLabel" Text="DPIs to test:" Grid.Row="3" Grid.Column="0"
                               VerticalAlignment="Center" Margin="0 4" Visibility="Collapsed"/>
                    <TextBlock x:Name="MrDpiListText" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                               TextWrapping="Wrap" Margin="4 4 0 4" Opacity="0.8" Visibility="Collapsed"/>

                    <!-- Full Test parameters (visible when ModeFullTest) -->
                    <TextBlock x:Name="FtLabel" Text="DPI Range:" Grid.Row="3" Grid.Column="0"
                               VerticalAlignment="Center" Margin="0 4" Visibility="Collapsed"/>
                    <StackPanel x:Name="FtPanel" Orientation="Horizontal" Grid.Row="3" Grid.Column="1"
                                Margin="4 4 0 4" Visibility="Collapsed">
                        <TextBlock Text="Min:" VerticalAlignment="Center" Margin="0 0 4 0"/>
                        <TextBox x:Name="FtMinBox" Width="70" Margin="0 0 8 0" IsReadOnly="True"/>
                        <TextBlock Text="Max:" VerticalAlignment="Center" Margin="0 0 4 0"/>
                        <TextBox x:Name="FtMaxBox" Width="70" Margin="0 0 8 0" IsReadOnly="True"/>
                        <TextBlock Text="Step:" VerticalAlignment="Center" Margin="0 0 4 0"/>
                        <TextBox x:Name="FtStepBox" Width="70" IsReadOnly="True"/>
                    </StackPanel>

                </Grid>
            </GroupBox>

            <!-- ── Test Parameters ─────────────────────────────────── -->
            <GroupBox Header="Test Parameters" Margin="0 0 0 12">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="150"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto" MinWidth="150"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Distance (mm):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <TextBox x:Name="DistanceBox" Grid.Row="0" Grid.Column="1" Text="100" Margin="4 4 0 4"/>

                    <TextBlock Text="Z Offset (mm):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <TextBox x:Name="ZOffsetBox" Grid.Row="1" Grid.Column="1" Text="2.5" Margin="4 4 0 4"/>

                    <TextBlock Text="Speed (0–800):" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                    <TextBox x:Name="SpeedBox" Grid.Row="0" Grid.Column="4" Text="200" Margin="4 4 0 4"/>

                    <TextBlock Text="Cycles:" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Margin="16 4 0 4"/>
                    <TextBox x:Name="CyclesBox" Grid.Row="1" Grid.Column="4" Text="5" Margin="4 4 0 4"/>

                    <TextBlock Text="Dev Threshold (%):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0 4"/>
                    <TextBox x:Name="ThresholdBox" Grid.Row="2" Grid.Column="1" Text="2.0" Margin="4 4 0 4"/>

                    <Button Content="Load Defaults" Grid.Row="2" Grid.Column="3"
                            Width="130" HorizontalAlignment="Left" Click="LoadDefaults_Click" Margin="16 4 0 4"/>
                </Grid>
            </GroupBox>

            <!-- ── Run ────────────────────────────────────────────── -->
            <GroupBox Header="Test Run" Margin="0 0 0 12">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                        <TextBlock Text="Output Folder:" VerticalAlignment="Center" Margin="0 0 8 0"/>
                        <TextBox x:Name="OutputFolderBox" Width="420" Margin="0 0 8 0"/>
                        <Button x:Name="BrowseBtn" Content="Browse..." Width="80" Click="BrowseBtn_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                        <Button x:Name="RunBtn" Content="▶ Run DPI Test" Width="160"
                                Click="RunBtn_Click" Margin="0 0 12 0"/>
                        <Button x:Name="CancelBtn" Content="■ Cancel" Width="100"
                                Click="CancelBtn_Click" IsEnabled="False" Margin="0 0 16 0"/>
                        <TextBlock x:Name="RunStatus" Text="Ready" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ProgressBar x:Name="Progress" Height="8" Minimum="0" Maximum="100" Value="0"/>
                </StackPanel>
            </GroupBox>

            <!-- ── Results ────────────────────────────────────────── -->
            <GroupBox Header="Results" Margin="0 0 0 12">
                <StackPanel Margin="8">
                    <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" Height="180"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              FontSize="12" Margin="0 0 0 8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Target DPI"   Binding="{Binding TargetDpi}"                                   Width="90"/>
                            <DataGridTextColumn Header="Axis"         Binding="{Binding Axis}"                                        Width="50"/>
                            <DataGridTextColumn Header="Avg DPI"      Binding="{Binding AverageDpi, StringFormat={}{0:F1}}"           Width="85"/>
                            <DataGridTextColumn Header="Avg Dev %"    Binding="{Binding AverageDeviationPct, StringFormat={}{0:F2}%}" Width="80"/>
                            <DataGridTextColumn Header="Res Error %"  Binding="{Binding ResolutionError, StringFormat={}{0:F2}%}"    Width="90"/>
                            <DataGridTextColumn Header="Pass"         Binding="{Binding PassText}"                                   Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ExportCsvBtn" Content="Export CSV" Width="120"
                                Click="ExportCsv_Click" IsEnabled="False" Margin="0 0 8 0"/>
                        <Button x:Name="ExportXlsxBtn" Content="Export XLSX" Width="120"
                                Click="ExportXlsx_Click" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
