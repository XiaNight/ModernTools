<base:PageBase x:Class="QuickScan.QuickScanPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:QuickScan"
             xmlns:base="clr-namespace:Base.Pages;assembly=Base"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="Scenario:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="ScenarioCombo" MinWidth="220" VerticalAlignment="Center"
                      DisplayMemberPath="Name"
                      SelectionChanged="ScenarioCombo_SelectionChanged"/>
            <Button x:Name="RunButton" Content="Run scan" Margin="8,0,0,0" Padding="12,4,12,4"
                    VerticalAlignment="Center" Click="Run_Click"/>
            <Button x:Name="CaptureButton" Content="Capture baseline" Margin="8,0,0,0" Padding="12,4,12,4"
                    VerticalAlignment="Center" Click="Capture_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Margin="8,0,0,0" Padding="12,4,12,4"
                    VerticalAlignment="Center" Click="Cancel_Click"/>
            <Button x:Name="ImportButton" Content="Import…" Margin="8,0,0,0" Padding="12,4,12,4"
                    VerticalAlignment="Center" Click="Import_Click"/>
            <Button x:Name="ExportButton" Content="Export…" Margin="8,0,0,0" Padding="12,4,12,4"
                    VerticalAlignment="Center" Click="Export_Click"/>
        </StackPanel>

        <!-- Summary -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,8">
            <TextBlock x:Name="SummaryText" Text="No scan yet." FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock x:Name="ProgressText" Text="" Margin="16,0,0,0" VerticalAlignment="Center" Opacity="0.8"/>
        </StackPanel>

        <!-- Entry list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ListPanel"/>
        </ScrollViewer>
    </Grid>
</base:PageBase>
