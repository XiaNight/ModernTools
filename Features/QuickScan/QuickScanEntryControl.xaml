<UserControl x:Class="QuickScan.QuickScanEntryControl"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:QuickScan"
			 xmlns:ui="http://schemas.modernwpf.com/2019"
			 mc:Ignorable="d"
			 d:DesignWidth="900">
	<UserControl.Resources>
		<!-- Feature-local status colours (self-contained, like Banner's severity colours). -->
		<SolidColorBrush x:Key="PassBg" Color="#3327C93F"/>
		<SolidColorBrush x:Key="FailBg" Color="#33FF3B30"/>
		<SolidColorBrush x:Key="SkipBg" Color="#22888888"/>
		<SolidColorBrush x:Key="PassFg" Color="#FF2FA84A"/>
		<SolidColorBrush x:Key="FailFg" Color="#FFE0342B"/>
	</UserControl.Resources>

	<Border x:Name="Container" Padding="10,7,10,7" CornerRadius="4"
			BorderThickness="1"
			Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
			BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Enable toggle -->
			<CheckBox x:Name="EnableCheck" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
					  VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="24"
					  Padding="0"
					  ToolTip="Include this protocol in the scan"
					  Checked="EnableCheck_Checked" Unchecked="EnableCheck_Unchecked" IsChecked="False" FontSize="14" Margin="0,0,3.7,0"/>

			<!-- Verdict badge -->
			<Border x:Name="Badge" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
					Width="52" Height="22" CornerRadius="4" Margin="0,0,10,0"
					VerticalAlignment="Center" Background="{StaticResource SkipBg}">
				<TextBlock x:Name="BadgeText" Text="—" FontWeight="SemiBold" FontSize="11"
						   HorizontalAlignment="Center" VerticalAlignment="Center"/>
			</Border>

			<!-- Name + detail -->
			<TextBlock x:Name="NameText" Grid.Row="0" Grid.Column="2" FontWeight="SemiBold"
					   TextWrapping="Wrap"
					   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
			<TextBlock x:Name="DetailText" Grid.Row="1" Grid.Column="2" FontFamily="Consolas"
					   FontSize="11" Opacity="0.75" TextWrapping="Wrap" Margin="0,2,0,0"/>

			<!-- Validation mode -->
			<ComboBox x:Name="ModeCombo" Grid.Row="0" Grid.Column="4" Grid.RowSpan="2"
					  Width="128" Margin="10,0,0,0" VerticalAlignment="Center"
					  ToolTip="How strictly the reply is judged"
					  SelectionChanged="ModeCombo_SelectionChanged">
				<ComboBoxItem>Structural</ComboBoxItem>
				<ComboBoxItem>Valid range</ComboBoxItem>
				<ComboBoxItem>Exact (baseline)</ComboBoxItem>
			</ComboBox>

			<!-- Index / parameter editors (shown only when relevant) -->
			<ui:SimpleStackPanel x:Name="ParamPanel" Grid.Row="0" Grid.Column="3" Grid.RowSpan="2" Orientation="Horizontal"
						Margin="10,0,0,0" VerticalAlignment="Center" Spacing="8">
				<TextBlock Text="idx" Width="28" FontSize="14" Opacity="0.7" VerticalAlignment="Center"/>
				<TextBox x:Name="IdxBox" Width="60" FontFamily="Consolas" FontSize="14" VerticalContentAlignment="Center"
						 LostFocus="IdxBox_LostFocus" ui:TextBoxHelper.IsDeleteButtonVisible="False"/>
				<TextBlock Text="data" Width="28" FontSize="14" Opacity="0.7" VerticalAlignment="Center"/>
				<TextBox x:Name="DataBox" Width="60" FontFamily="Consolas" FontSize="14" VerticalContentAlignment="Center"
						 LostFocus="DataBox_LostFocus" ui:TextBoxHelper.IsDeleteButtonVisible="False"/>
			</ui:SimpleStackPanel>

			<!-- Baseline indicator -->
			<TextBlock x:Name="BaselineText" Grid.Row="1" Grid.Column="3" FontSize="12" Text="Example Text"
					   Opacity="0.6" Margin="0,2,0,0" Visibility="Collapsed"/>
		</Grid>
	</Border>
</UserControl>
