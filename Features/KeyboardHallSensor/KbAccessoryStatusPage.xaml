<base:PageBase x:Class="KeyboardHallSensor.KbAccessoryStatusPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:KeyboardHallSensor"
             xmlns:base="clr-namespace:Base.Pages;assembly=Base"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 12">
            <Button x:Name="RefreshBtn" Content="Refresh" Width="100" FontSize="14"
                    Click="RefreshBtn_Click" Margin="0 0 12 0"/>
            <CheckBox x:Name="AutoRefreshCheck" Content="Auto refresh" FontSize="14"
                      IsChecked="False" VerticalAlignment="Center"/>
            <TextBlock Text="Test Mode: " FontSize="14" VerticalAlignment="Center" TextAlignment="Center"/>
            <ComboBox x:Name="TestModeDropdown" Width="140" VerticalAlignment="Center">
                <ComboBoxItem Content="Off" IsSelected="True"/>
                <ComboBoxItem Content="Accessory Type"/>
                <ComboBoxItem Content="All"/>
            </ComboBox>
        </StackPanel>

        <!-- Status table -->
        <GroupBox Grid.Row="1" VerticalAlignment="Top">
            <GroupBox.Header>
                <TextBlock Text="KB Accessory - Key Status" FontSize="20"/>
            </GroupBox.Header>
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <!-- 8-column table is built in code-behind -->
                <Grid x:Name="TableHost" Margin="8"/>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</base:PageBase>
