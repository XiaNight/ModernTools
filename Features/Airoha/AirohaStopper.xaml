<base:PageBase x:Class="Airoha.AirohaStopper"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Airoha"
             xmlns:base="clr-namespace:Base.Pages;assembly=Base"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="6">
            <Button Content="Refresh" Click="RefreshButton_Click" Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
        </StackPanel>

        <TreeView x:Name="AutomationTreeView" Grid.Row="1" Margin="6"/>
    </Grid>
</base:PageBase>
