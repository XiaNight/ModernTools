<UserControl x:Class="Base.UI.Pages.QuickActionEntryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignWidth="600" d:DesignHeight="68">

    <!-- Outer border -->
    <Border CornerRadius="4"
            Padding="6,4,6,4"
            Margin="0,0,0,4"
            BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>    <!-- Send -->
                <ColumnDefinition Width="*"/>     <!-- Name -->
                <ColumnDefinition Width="Auto"/>    <!-- Edit -->
                <ColumnDefinition Width="Auto"/>    <!-- Delete -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Send button -->
            <Button x:Name="SendButton"
                    Grid.Column="0" Grid.Row="0"
                    Padding="6 4"
                    Margin="0 0 4 0"
                    VerticalAlignment="Stretch"
                    ToolTip="Send all commands">
                <ui:FontIcon Glyph="&#xE768;" FontSize="18" FontFamily="Segoe Fluent Icons"/>
            </Button>

            <!-- Name text box -->
            <TextBox x:Name="NameBox"
                     Grid.Column="1" Grid.Row="0"
                     FontSize="12"
                     VerticalContentAlignment="Center"
                     Margin="0,0,4,0"
                     MinWidth="80"/>

            <!-- Preview block (truncated, clickable -> opens popup) -->
            <TextBlock x:Name="PreviewBlock"
                       Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="5"
                       FontFamily="Consolas"
                       FontSize="12"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="4,4,4,0"
                       Cursor="Hand"
                       ToolTip="Click to view/edit full commands"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

            <!-- Edit button -->
            <Button x:Name="EditButton"
                    Grid.Column="2" Grid.Row="0"
                    Padding="6 4"
                    Margin="0 0 4 0"
                    VerticalAlignment="Stretch"
                    ToolTip="Edit commands">
                <ui:FontIcon Glyph="&#xE70F;" FontSize="16" FontFamily="Segoe Fluent Icons"/>
            </Button>

            <!-- Delete button -->
            <Button x:Name="DeleteButton"
                    Grid.Column="3" Grid.Row="0"
                    Padding="8 6"
                    VerticalAlignment="Stretch"
                    ToolTip="Delete entry">
                <ui:FontIcon Glyph="&#xE74D;" FontSize="16" FontFamily="Segoe Fluent Icons"/>
            </Button>
        </Grid>
    </Border>

    <!-- Command edit popup (defined in code-behind because Popup is not a visual child) -->
</UserControl>
