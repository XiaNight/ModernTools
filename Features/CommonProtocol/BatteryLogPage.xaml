<base:PageBase x:Class="CommonProtocol.BatteryLogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CommonProtocol"
             xmlns:base="clr-namespace:Base.Pages;assembly=Base"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800" d:Background="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ui:SimpleStackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button x:Name="StartStopButton" Content="Start" MinWidth="80" Click="StartStopButton_Click"/>
            <TextBlock Text="Interval:" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBox x:Name="IntervalBox" Text="5" Width="48"
                     VerticalContentAlignment="Center"/>
            <TextBlock Text="s" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock x:Name="StatusText" Text="Idle." VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"/>
        </ui:SimpleStackPanel>

        <!-- Chart container — FastStripChartControl inserted in code-behind -->
        <Border x:Name="ChartBorder" Grid.Row="1" Margin="12"
                CornerRadius="6"/>

        <!-- Stats -->
        <ui:SimpleStackPanel Grid.Row="2" Orientation="Horizontal" Spacing="20" Margin="0,8,0,0">
            <TextBlock x:Name="RsocText" Text="RSOC: --%"
                       Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
            <TextBlock x:Name="VoltageText" Text="Voltage: -- mV"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock x:Name="SampleText" Text="Samples: 0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </ui:SimpleStackPanel>
    </Grid>
</base:PageBase>
