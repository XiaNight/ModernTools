<base:PageBase x:Class="Base.UI.Pages.ASUSBusHoundPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Base.UI.Pages"
             xmlns:base="clr-namespace:Base.Pages;assembly=Base"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1170" d:Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ui:SimpleStackPanel Orientation="Horizontal" Spacing="4" Grid.Row="0" Visibility="Visible">
            <Button x:Name="CaptureBtn" Width="64" Height="48" Padding="0">
                <ui:SimpleStackPanel Orientation="Vertical">
                    <ui:FontIcon Glyph="&#xE9D2;" FontSize="22" FontFamily="Segoe Fluent Icons"/>
                    <TextBlock Text="Capture" FontSize="12" />
                </ui:SimpleStackPanel>
            </Button>
            <Button x:Name="SaveBtn" Width="64" Height="48" Padding="0">
                <ui:SimpleStackPanel Orientation="Vertical">
                    <ui:FontIcon Glyph="&#xE74E;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
                    <TextBlock Text="Save" FontSize="12"/>
                </ui:SimpleStackPanel>
            </Button>
            <Button x:Name="SettingsBtn" Width="64" Height="48" Padding="0">
                <ui:SimpleStackPanel Orientation="Vertical">
                    <ui:FontIcon Glyph="&#xE713;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
                    <TextBlock Text="Settings" FontSize="12"/>
                </ui:SimpleStackPanel>
            </Button>
            <Button x:Name="DevicesBtn" Width="64" Height="48" Padding="0" IsEnabled="False" ToolTip="Upcoming...">
                <ui:SimpleStackPanel Orientation="Vertical">
                    <ui:FontIcon Glyph="&#xEA6C;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
                    <TextBlock Text="Devices" FontSize="12"/>
                </ui:SimpleStackPanel>
            </Button>
            <Button x:Name="QuickActionBtn" Width="64" Height="48" Padding="0">
                <ui:SimpleStackPanel Orientation="Vertical">
                    <ui:FontIcon Glyph="&#xE70B;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
                    <TextBlock Text="Action" FontSize="12"/>
                </ui:SimpleStackPanel>
            </Button>
        </ui:SimpleStackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="QuickActionColumnDef" Width="0"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="LogGrid"
                      ItemsSource="{Binding Items}"
                      Grid.Column="0"
                      AutoGenerateColumns="False"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      CanUserSortColumns="False">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Page" Binding="{Binding Device}" Width="Auto" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Phase" Binding="{Binding Phase}" Width="Auto" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataString}" Width="4*" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="Auto" FontFamily="Consolas"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Quick Action Panel -->
            <Border x:Name="QuickActionPanel" Grid.Column="1" Visibility="Collapsed"
                    Margin="4,0,0,0" Padding="4"
                    CornerRadius="8 0 0 8" BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="QuickActionImportBtn"
                                Grid.Column="0"
                                Padding="8,4" Margin="6 4" ToolTip="Import from bin or txt file">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon Glyph="&#xE8B5;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Import" FontSize="14" VerticalAlignment="Center"/>
                            </ui:SimpleStackPanel>
                        </Button>
                        <Button x:Name="QuickActionAddBtn"
                                Grid.Column="1"
                                Padding="8,4" Margin="6 4" ToolTip="Add a new empty entry">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon Glyph="&#xE710;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Add" FontSize="14" VerticalAlignment="Center"/>
                            </ui:SimpleStackPanel>
                        </Button>
                        <Button x:Name="QuickActionCloseBtn"
                                Grid.Column="3"
                                Padding="8,4" Margin="6 4" ToolTip="Close panel"
                                HorizontalAlignment="Right">
                            <ui:FontIcon Glyph="&#xE8BB;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                        </Button>
                    </Grid>

                    <!-- Scrollable entry list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="QuickActionEntriesPanel" Orientation="Vertical"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="UsageSelectionBox" Grid.Column="0" Margin="4" MinWidth="150"/>
            <TextBox x:Name="Inputbox" Grid.Column="1" Margin="4"/>
            <Button x:Name="SendBtn" Width="48" Height="32" Margin="4" Grid.Column="2">
                <ui:FontIcon Glyph="&#xE724;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
            </Button>
            <Button x:Name="StartBtn" Width="48" Height="32" Margin="4" Grid.Column="3">
                <ui:SimpleStackPanel Orientation="Vertical">
                    <TextBlock Text="Run" FontSize="12"/>
                </ui:SimpleStackPanel>
            </Button>
            <Button x:Name="StopBtn" Width="48" Height="32" Margin="4" Grid.Column="4" IsEnabled="False">
                <ui:SimpleStackPanel Orientation="Vertical">
                    <TextBlock Text="Stop" FontSize="12"/>
                </ui:SimpleStackPanel>
            </Button>
        </Grid>

    </Grid>
</base:PageBase>
