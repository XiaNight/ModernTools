<UserControl x:Class="Base.UI.Pages.QuickActionFolderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignWidth="360" d:DesignHeight="200">

    <Border CornerRadius="6"
            Padding="6,4"
            Margin="0,0,0,6"
            BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        <StackPanel>

            <!-- Folder header row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Expand / Collapse chevron -->
                <Button x:Name="ExpandButton"
                        Grid.Column="0"
                        Padding="4,2"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ToolTip="Expand / Collapse">
                    <ui:FontIcon x:Name="ExpandChevron"
                                 Glyph="&#xE70D;"
                                 FontSize="12"
                                 FontFamily="Segoe Fluent Icons"/>
                </Button>

                <!-- Folder icon -->
                <ui:FontIcon Grid.Column="1"
                             Glyph="&#xED41;"
                             FontSize="16"
                             FontFamily="Segoe Fluent Icons"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>

                <!-- Folder name text box -->
                <TextBox x:Name="FolderNameBox"
                         Grid.Column="2"
                         FontSize="13"
                         FontWeight="SemiBold"
                         VerticalContentAlignment="Center"
                         Margin="0,0,4,0"/>

                <!-- Export folder button -->
                <Button x:Name="ExportButton"
                        Grid.Column="3"
                        Padding="6,4"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ToolTip="Export folder to JSON">
                    <ui:FontIcon Glyph="&#xEDE1;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                </Button>

                <!-- Add entry button -->
                <Button x:Name="AddEntryButton"
                        Grid.Column="4"
                        Padding="6,4"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ToolTip="Add new entry to this folder">
                    <ui:FontIcon Glyph="&#xE710;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                </Button>

                <!-- Delete folder button -->
                <Button x:Name="DeleteFolderButton"
                        Grid.Column="5"
                        Padding="6,4"
                        VerticalAlignment="Center"
                        ToolTip="Delete this folder">
                    <ui:FontIcon Glyph="&#xE74D;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                </Button>
            </Grid>

            <!-- Entries panel (shown/hidden based on IsExpanded) -->
            <StackPanel x:Name="FolderEntriesPanel" Margin="20,4,0,2"/>

        </StackPanel>
    </Border>
</UserControl>
