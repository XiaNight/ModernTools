<base:PageBase x:Class="CommonProtocol.BusHound.ASUSBusHoundPage"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:CommonProtocol"
			 xmlns:base="clr-namespace:Base.Pages;assembly=Base"
			 xmlns:ui="http://schemas.modernwpf.com/2019"
			 mc:Ignorable="d" 
			 d:DesignHeight="600" d:DesignWidth="1170" d:Background="White">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<ui:SimpleStackPanel Orientation="Horizontal" Spacing="4" Grid.Row="0" Visibility="Visible">
			<Button x:Name="CaptureBtn" Width="64" Height="48" Padding="0">
				<ui:SimpleStackPanel Orientation="Vertical">
					<ui:FontIcon Glyph="&#xE9D2;" FontSize="22" FontFamily="Segoe Fluent Icons"/>
					<TextBlock Text="Capture" FontSize="12" />
				</ui:SimpleStackPanel>
			</Button>
			<Button x:Name="SaveBtn" Width="64" Height="48" Padding="0">
				<ui:SimpleStackPanel Orientation="Vertical">
					<ui:FontIcon Glyph="&#xE74E;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
					<TextBlock Text="Save" FontSize="12"/>
				</ui:SimpleStackPanel>
			</Button>
			<Button x:Name="DevicesBtn" Width="64" Height="48" Padding="0" ToolTip="Show the tree of connected USB devices">
				<ui:SimpleStackPanel Orientation="Vertical">
					<ui:FontIcon Glyph="&#xEA6C;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
					<TextBlock Text="Devices" FontSize="12"/>
				</ui:SimpleStackPanel>
			</Button>
			<Button x:Name="QuickActionBtn" Width="64" Height="48" Padding="0">
				<ui:SimpleStackPanel Orientation="Vertical">
					<ui:FontIcon Glyph="&#xE70B;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
					<TextBlock Text="Action" FontSize="12"/>
				</ui:SimpleStackPanel>
			</Button>
			<Button x:Name="TestsBtn" Width="64" Height="48" Padding="0">
				<ui:SimpleStackPanel Orientation="Vertical">
					<ui:FontIcon Glyph="&#xE762;"  FontSize="22" FontFamily="Segoe Fluent Icons"/>
					<TextBlock Text="Tests" FontSize="12"/>
				</ui:SimpleStackPanel>
			</Button>
		</ui:SimpleStackPanel>

		<Grid x:Name="TestsPanel" Grid.Row="1" Visibility="Collapsed">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Header -->
			<Grid Grid.Row="0" Margin="4,4,4,8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0" Text="Protocol Tests" FontSize="16" FontWeight="SemiBold"
						   VerticalAlignment="Center"
						   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<TextBlock x:Name="TestsSummaryText" Grid.Column="1" Margin="12,0,0,0"
						   VerticalAlignment="Center"
						   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

				<Button x:Name="TestsRunAllBtn" Grid.Column="2" Margin="4,0"
						ToolTip="Run all tests in order">
					<ui:SimpleStackPanel Orientation="Horizontal" Spacing="6">
						<ui:FontIcon Glyph="&#xE768;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
						<TextBlock Text="Run all"/>
					</ui:SimpleStackPanel>
				</Button>

				<Button x:Name="TestsAddBtn" Grid.Column="3" Margin="4,0"
						ToolTip="Add a new test">
					<ui:SimpleStackPanel Orientation="Horizontal" Spacing="6">
						<ui:FontIcon Glyph="&#xE710;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
						<TextBlock Text="Add"/>
					</ui:SimpleStackPanel>
				</Button>
			</Grid>

			<!-- Test list -->
			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="4,0">
				<StackPanel x:Name="TestsListPanel"/>
			</ScrollViewer>

			<TextBlock x:Name="TestsEmptyText" Grid.Row="1"
					   Text="No tests yet. Click Add to create one."
					   HorizontalAlignment="Center" VerticalAlignment="Center"
					   Opacity="0.7"
					   Visibility="Collapsed"/>
		</Grid>

		<Grid x:Name="DevicePanel" Grid.Row="1" Visibility="Collapsed">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Header -->
			<Grid Grid.Row="0" Margin="4,4,4,8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Connected USB Devices" FontSize="16" FontWeight="SemiBold"
						   VerticalAlignment="Center"
						   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
				<TextBlock x:Name="DeviceSummaryText" Grid.Column="1" Margin="12,0,0,0"
						   VerticalAlignment="Center" FontSize="13"
						   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
				<Button x:Name="DeviceRefreshBtn" Grid.Column="2" Height="32" Padding="8,4" ToolTip="Refresh device list">
					<ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
						<ui:FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
						<TextBlock Text="Refresh" FontSize="14" VerticalAlignment="Center"/>
					</ui:SimpleStackPanel>
				</Button>
			</Grid>

			<!-- Device tree -->
			<Grid Grid.Row="1">
				<TreeView x:Name="DeviceTree"
						  ItemsSource="{Binding DeviceNodes}"
						  BorderThickness="0"
						  Background="Transparent"
						  ScrollViewer.HorizontalScrollBarVisibility="Auto"
						  VirtualizingPanel.IsVirtualizing="True"
						  VirtualizingPanel.VirtualizationMode="Recycling">
					<TreeView.ItemContainerStyle>
						<Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
							<Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
						</Style>
					</TreeView.ItemContainerStyle>
					<TreeView.Resources>
						<HierarchicalDataTemplate DataType="{x:Type local:UsbTreeNode}" ItemsSource="{Binding Children}">
							<ui:SimpleStackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
								<ui:FontIcon Glyph="{Binding Glyph}" FontSize="16" FontFamily="Segoe Fluent Icons"
											 VerticalAlignment="Center"
											 Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
								<TextBlock Text="{Binding Title}" FontSize="14" VerticalAlignment="Center"
										   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
								<TextBlock Text="{Binding Detail}" FontSize="13" VerticalAlignment="Center"
										   FontFamily="Consolas"
										   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
							</ui:SimpleStackPanel>
						</HierarchicalDataTemplate>
					</TreeView.Resources>
				</TreeView>
				<TextBlock x:Name="DeviceEmptyText"
						   Text="No connected devices found."
						   Visibility="Collapsed"
						   HorizontalAlignment="Center" VerticalAlignment="Center"
						   FontSize="14"
						   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
			</Grid>
		</Grid>
		<Grid x:Name="CapturePanel" Grid.Row="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<Grid Grid.Row="0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition x:Name="QuickActionColumnDef" Width="0"/>
				</Grid.ColumnDefinitions>

				<DataGrid x:Name="LogGrid"
						  ItemsSource="{Binding Items}"
						  Grid.Column="0"
						  AutoGenerateColumns="False"
						  EnableRowVirtualization="True"
						  EnableColumnVirtualization="True"
						  VirtualizingPanel.IsVirtualizing="True"
						  VirtualizingPanel.VirtualizationMode="Recycling"
						  ScrollViewer.CanContentScroll="True"
						  HeadersVisibility="Column"
						  IsReadOnly="True"
						  CanUserSortColumns="False">

					<DataGrid.Columns>
						<DataGridTextColumn Header="Page" Binding="{Binding Device}" Width="Auto" FontFamily="Consolas"/>
						<DataGridTextColumn Header="Phase" Binding="{Binding Phase}" Width="Auto" FontFamily="Consolas"/>
						<DataGridTextColumn Header="Data" Binding="{Binding DataString}" Width="4*" FontFamily="Consolas"/>
						<DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" FontFamily="Consolas"/>
						<DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="Auto" FontFamily="Consolas"/>
					</DataGrid.Columns>
				</DataGrid>

				<!-- Quick Action Panel -->
				<Border x:Name="QuickActionPanel" Grid.Column="1" Visibility="Collapsed"
						Margin="4,0,0,0" Padding="4"
						CornerRadius="8 0 0 8" BorderThickness="1"
						BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
						Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<!-- Toolbar -->
						<Grid Grid.Row="0" Margin="0,0,0,4">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<!-- Button row -->
							<Grid Grid.Row="0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Button x:Name="QuickActionImportBtn"
										Grid.Column="0" Height="32"
										Padding="8,4" Margin="6,4" ToolTip="Import folder from JSON, or entry from bin/txt file">
									<ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
										<ui:FontIcon Glyph="&#xE8B5;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
										<TextBlock Text="Import" FontSize="14" VerticalAlignment="Center"/>
									</ui:SimpleStackPanel>
								</Button>
								<Button x:Name="QuickActionAddBtn"
										Grid.Column="1" Height="32"
										Padding="8,4" Margin="6,4" ToolTip="Add a new folder">
									<ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
										<ui:FontIcon Glyph="&#xED41;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
										<TextBlock Text="Add Folder" FontSize="14" VerticalAlignment="Center"/>
									</ui:SimpleStackPanel>
								</Button>
								<Button x:Name="QuickActionCloseBtn"
										Grid.Column="3" Height="32"
										Padding="8,4" Margin="6,4" ToolTip="Close panel"
										HorizontalAlignment="Right">
									<ui:FontIcon Glyph="&#xE89F;" FontSize="18" FontFamily="Segoe Fluent Icons"/>
								</Button>
							</Grid>

							<!-- Search row -->
							<Grid Grid.Row="1" Margin="12,4,6,4">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<ui:FontIcon Grid.Column="0"
											 Glyph="&#xE721;"
											 FontSize="14"
											 FontFamily="Segoe Fluent Icons"
											 VerticalAlignment="Center"
											 Margin="2,0,12,0"
											 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
								<TextBox x:Name="QuickActionSearchBox"
										 Grid.Column="1"
										 Height="30"
										 VerticalContentAlignment="Center"
										 ui:ControlHelper.PlaceholderText="Search by name or command…"/>
							</Grid>
						</Grid>

						<!-- Scrollable folder list -->
						<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
							<StackPanel x:Name="QuickActionEntriesPanel" Orientation="Vertical"/>
						</ScrollViewer>
					</Grid>
				</Border>
			</Grid>

			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<ComboBox x:Name="UsageSelectionBox" Grid.Column="0" Margin="4" MinWidth="150"/>
				<StackPanel Grid.Column="1" Orientation="Horizontal">
					<ComboBox x:Name="PipeSelectionBox" Margin="4" MinWidth="128" ToolTip="Endpoint used to send commands">
						<ComboBoxItem Content="Interrupt" IsSelected="True"/>
						<ComboBoxItem Content="Control (Output)"/>
						<ComboBoxItem Content="Control (Feature)"/>
					</ComboBox>
					<TextBox x:Name="ReportIdBox" Margin="4" Width="56" VerticalContentAlignment="Center" ui:ControlHelper.PlaceholderText="ID" ToolTip="Report ID byte in hex (e.g. CC). Blank or 00 = device default."/>
				</StackPanel>
				<TextBox x:Name="CmdInputbox" Grid.Column="2" Margin="4"/>
				<Button x:Name="SendBtn" Width="48" Height="32" Margin="4" Grid.Column="3" Padding="0">
					<ui:FontIcon Glyph="&#xE724;" FontSize="18" FontFamily="Segoe Fluent Icons"/>
				</Button>
				<Button x:Name="PollBtn" Width="48" Height="32" Margin="4" Grid.Column="4" Padding="0" ToolTip="Read one report over the control pipe (GET_REPORT)">
					<ui:FontIcon Glyph="&#xE72C;" FontSize="18" FontFamily="Segoe Fluent Icons"/>
				</Button>
				<Button x:Name="StartBtn" Width="48" Height="32" Margin="4" Grid.Column="5">
					<ui:SimpleStackPanel Orientation="Vertical">
						<TextBlock Text="Run" FontSize="14"/>
					</ui:SimpleStackPanel>
				</Button>
				<Button x:Name="StopBtn" Width="48" Height="32" Margin="4" Grid.Column="6" IsEnabled="False">
					<ui:SimpleStackPanel Orientation="Vertical">
						<TextBlock Text="Stop" FontSize="14"/>
					</ui:SimpleStackPanel>
				</Button>
			</Grid>
		</Grid>
	</Grid>
</base:PageBase>
