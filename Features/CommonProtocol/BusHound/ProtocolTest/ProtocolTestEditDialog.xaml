<ui:ContentDialog x:Class="CommonProtocol.BusHound.ProtocolTest.ProtocolTestEditDialog"
				  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
				  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				  xmlns:ui="http://schemas.modernwpf.com/2019"
				  xmlns:local="clr-namespace:CommonProtocol"
				  mc:Ignorable="d"
				  Title="Edit test"
				  PrimaryButtonText="Save"
				  CloseButtonText="Cancel"
				  DefaultButton="Primary">
	<StackPanel MinWidth="420" Margin="0,4,0,0">

		<TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
		<TextBox x:Name="NameBox" Margin="0,0,0,12"/>

		<TextBlock Text="Request bytes" FontWeight="SemiBold" Margin="0,0,0,4"/>
		<TextBox x:Name="RequestBox"
				 FontFamily="Consolas"
				 Margin="0,0,0,2"/>
		<TextBlock Text="Hex bytes to send, e.g. 02 00 B5 00."
				   FontSize="11"
				   Opacity="0.7"
				   Margin="0,0,0,12"/>

		<TextBlock Text="Expected return packets" FontWeight="SemiBold" Margin="0,0,0,4"/>
		<TextBox x:Name="ExpectedBox"
				 FontFamily="Consolas"
				 AcceptsReturn="True"
				 TextWrapping="NoWrap"
				 VerticalScrollBarVisibility="Auto"
				 HorizontalScrollBarVisibility="Auto"
				 MinHeight="96"
				 MaxHeight="220"
				 Margin="0,0,0,2"/>
		<TextBlock Text="One packet per line. Bytes must match exactly; use X for a wildcard nibble (e.g. 02 F4 XX 1X)."
				   FontSize="11"
				   Opacity="0.7"
				   TextWrapping="Wrap"
				   Margin="0,0,0,6"/>

		<!-- Record: fires the request and streams received packets into the expected field -->
		<ui:SimpleStackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
			<Button x:Name="RecordButton">
				<ui:SimpleStackPanel Orientation="Horizontal" Spacing="6">
					<ui:FontIcon x:Name="RecordIcon" Glyph="&#xE7C8;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
					<TextBlock x:Name="RecordButtonText" Text="Record"/>
				</ui:SimpleStackPanel>
			</Button>
			<TextBlock x:Name="RecordStatusText"
					   VerticalAlignment="Center"
					   FontSize="12"
					   Opacity="0.8"/>
		</ui:SimpleStackPanel>

		<CheckBox x:Name="TrailingWildcardCheck"
				  Content="Allow extra trailing bytes (treated as wildcard)"
				  IsChecked="True"
				  Margin="0,0,0,12"/>

		<TextBlock Text="Total timeout (ms)" FontWeight="SemiBold" Margin="0,0,0,4"/>
		<ui:NumberBox x:Name="TimeoutBox"
					  Minimum="0"
					  Maximum="600000"
					  Value="10"
					  HorizontalAlignment="Left"
					  MinWidth="160"
					  Margin="0,0,0,4"/>

		<TextBlock x:Name="ErrorText"
				   Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
				   TextWrapping="Wrap"
				   Visibility="Collapsed"
				   Margin="0,8,0,0"/>
	</StackPanel>
</ui:ContentDialog>