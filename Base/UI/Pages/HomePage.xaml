<local:PageBase x:Class="Base.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Base.Pages"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400" d:Background="White">

    <local:PageBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlAcrylicWindowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style x:Key="QuickAccessButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="MinHeight" Value="88" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="MiniStatCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>
    </local:PageBase.Resources>

    <Grid Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Workspace Overview"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Text="Quick access, recent pages, diagnostics, and local machine information." />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentTimeText, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                            <TextBlock Text="{Binding CurrentMachineText, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="2.1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Quick Access -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                        <StackPanel>
                            <TextBlock Text="Quick Access" Style="{StaticResource SectionTitleStyle}" />
                            <UniformGrid Columns="3" Rows="2">
                                <Button Style="{StaticResource QuickAccessButtonStyle}" Margin="0,0,12,12" Tag="Keyboard">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="⌨"
                                                   FontSize="28"
                                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Keyboard"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Profiles, keymaps, firmware"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource QuickAccessButtonStyle}" Margin="0,0,12,12" Tag="Mouse">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="🖱"
                                                   FontSize="28"
                                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Mouse"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Polling, DPI, button config"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource QuickAccessButtonStyle}" Margin="0,0,0,12" Tag="Gamepad">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="🎮"
                                                   FontSize="28"
                                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Gamepad"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Inputs, testing, mapping"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource QuickAccessButtonStyle}" Margin="0,0,12,0" Tag="Audio">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="🔊"
                                                   FontSize="28"
                                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Audio"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Endpoints, test tones, routing"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource QuickAccessButtonStyle}" Margin="0,0,12,0" Tag="ATE">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="🧪"
                                                   FontSize="28"
                                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="ATE"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Automation and test execution"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource QuickAccessButtonStyle}" Margin="0" Tag="Log">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="📄"
                                                   FontSize="28"
                                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Log"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Logs, diagnostics, traces"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Right upper dashboard -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="System Snapshot" Style="{StaticResource SectionTitleStyle}" />

                            <WrapPanel>
                                <Border Style="{StaticResource MiniStatCardStyle}" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="APP VERSION"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                        <TextBlock Text="{Binding AppVersion, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                                   Margin="0,6,0,0"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Current running build"
                                                   Margin="0,4,0,0"
                                                   Opacity="0.7" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MiniStatCardStyle}" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="UPTIME"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                        <TextBlock Text="{Binding MachineInfo.Uptime, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                                   Margin="0,6,0,0"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Since last reboot"
                                                   Margin="0,4,0,0"
                                                   Opacity="0.7" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MiniStatCardStyle}" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="MEMORY LOAD"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                        <TextBlock Text="{Binding MachineInfo.RamUsagePercentText, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                                   Margin="0,6,0,0"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding MachineInfo.RamDisplay, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                                   Margin="0,4,0,0"
                                                   Opacity="0.7" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MiniStatCardStyle}" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="SYSTEM DRIVE"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                        <TextBlock Text="{Binding MachineInfo.DiskUsedPercentText, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                                   Margin="0,6,0,0"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding MachineInfo.DiskDisplay, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                                   Margin="0,4,0,0"
                                                   Opacity="0.7" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource CardBorderStyle}"
                                        Padding="14"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Suggested Actions"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,10" />
                                        <TextBlock Text="• Connect a device and verify firmware"
                                                   Opacity="0.8"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Open Gamepad testing for input validation"
                                                   Opacity="0.8"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Review logs after hardware operations"
                                                   Opacity="0.8"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Use ATE when running repeatable checks"
                                                   Opacity="0.8" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Style="{StaticResource CardBorderStyle}"
                                        Padding="14"
                                        Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Machine Flags"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,10" />
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="OS:"
                                                       Width="110"
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding MachineInfo.WindowsVersion, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="User:"
                                                       Width="110"
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding MachineInfo.UserName, RelativeSource={RelativeSource AncestorType=local:HomePage}}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="Machine:"
                                                       Width="110"
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding MachineInfo.MachineName, RelativeSource={RelativeSource AncestorType=local:HomePage}}" />
                                        </DockPanel>
                                        <DockPanel>
                                            <TextBlock Text="System Drive:"
                                                       Width="110"
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding MachineInfo.SystemDrive, RelativeSource={RelativeSource AncestorType=local:HomePage}}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Recent Pages -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="Recent Pages"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                                <TextBlock DockPanel.Dock="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           Text="placeholder" />
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding RecentPages, RelativeSource={RelativeSource AncestorType=local:HomePage}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="🕘"
                                                           FontSize="18"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center" />

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="14" />
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Opacity="0.75"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding LastOpened}"
                                                           Opacity="0.7"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- PC Specs -->
                    <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="This PC"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                                <Button DockPanel.Dock="Right"
                                        Width="90"
                                        Height="32"
                                        Click="RefreshSpecsButton_Click"
                                        Content="Refresh" />
                            </DockPanel>

                            <Border Style="{StaticResource CardBorderStyle}" Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="CPU" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.CpuName, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="RAM" Grid.Row="1" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.RamDisplay, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="GPU" Grid.Row="2" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.GpuName, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="Disk" Grid.Row="3" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.DiskDisplay, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="Windows" Grid.Row="4" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.WindowsVersion, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="Machine" Grid.Row="5" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.MachineName, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="User" Grid.Row="6" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.UserName, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="Runtime" Grid.Row="7" Grid.Column="0" Margin="0,0,0,10" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.DotNetVersion, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="7" Grid.Column="1" Margin="0,0,0,10" TextWrapping="Wrap" />

                                    <TextBlock Text="Last Updated" Grid.Row="8" Grid.Column="0" Opacity="0.7" />
                                    <TextBlock Text="{Binding MachineInfo.LastUpdated, RelativeSource={RelativeSource AncestorType=local:HomePage}}" Grid.Row="8" Grid.Column="1" TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <ProgressBar Margin="0,12,0,0"
                                         Height="8"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding MachineInfo.RamUsagePercent, RelativeSource={RelativeSource AncestorType=local:HomePage}}" />
                            <TextBlock Text="{Binding MachineInfo.RamUsageBarText, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                       Margin="0,6,0,12"
                                       Opacity="0.7" />

                            <ProgressBar Height="8"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding MachineInfo.DiskUsedPercent, RelativeSource={RelativeSource AncestorType=local:HomePage}}" />
                            <TextBlock Text="{Binding MachineInfo.DiskBarText, RelativeSource={RelativeSource AncestorType=local:HomePage}}"
                                       Margin="0,6,0,0"
                                       Opacity="0.7" />
                        </StackPanel>
                    </Border>

                    <!-- Bottom center/left filler -->
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Notes / Space for More Widgets"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Good candidates here: connected devices, latest logs, current test session, environment selector, pinned tools, or build artifacts."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</local:PageBase>