<local:PageBase x:Class="Base.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:ctrl="clr-namespace:Base.UI.Controls"
             xmlns:local="clr-namespace:Base.Pages"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1080">

    <local:PageBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Surfaces / text / accent all resolved via DynamicResource so the page follows the
             active theme (light/dark) and the active accent colour (ROG red / anniversary gold). -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style x:Key="SpecLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="SpecValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
		
        <Style TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </local:PageBase.Resources>

    <!-- Fixed (non-scrolling) page: header on top, three equal-height columns fill the rest. -->
    <Grid Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentTimeText}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               FontFamily="Consolas, Cascadia Mono, Consolas"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                    <TextBlock Text="{Binding CurrentMachineText}"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="4"
                            CornerRadius="2"
                            Margin="0,2,14,2"
                            Background="{DynamicResource SystemControlForegroundAccentBrush}"
                            BorderThickness="0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Workspace Overview"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Text="Jump to a tool, revisit recent pages, and check this machine at a glance." />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body: Quick Access | Recent Pages | This PC, side by side, filling the height. -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" MinWidth="340" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" MinWidth="260" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Quick Access (2 x 3 tiles filling the column) -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Quick Access"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,14" />
                    <UniformGrid Columns="2" Rows="3" Margin="-6">
                        <ctrl:QuickAccessTile Margin="6" Glyph="&#xE765;" Target="Keyboard"
                                              Title="Keyboard" Subtitle="Profiles, keymaps, hall effect"
                                              Click="QuickAccess_Click" />
                        <ctrl:QuickAccessTile Margin="6" Glyph="&#xE962;" Target="Mouse"
                                              Title="Mouse" Subtitle="Sensor, DPI, button config"
                                              Click="QuickAccess_Click" />
                        <ctrl:QuickAccessTile Margin="6" Glyph="&#xE7FC;" Target="Gamepad"
                                              Title="Gamepad" Subtitle="Inputs, testing, mapping"
                                              Click="QuickAccess_Click" />
                        <ctrl:QuickAccessTile Margin="6" Glyph="&#xE767;" Target="Audio"
                                              Title="Audio" Subtitle="Endpoints, test tones, routing"
                                              Click="QuickAccess_Click" />
                        <ctrl:QuickAccessTile Margin="6" Glyph="&#xE90F;" Target="ATE"
                                              Title="ATE" Subtitle="Automation and test execution"
                                              Click="QuickAccess_Click" />
                        <ctrl:QuickAccessTile Margin="6" Glyph="&#xE9D9;" Target="Log"
                                              Title="Output Log" Subtitle="Open the diagnostics log panel"
                                              Click="QuickAccess_Click" />
                    </UniformGrid>
                </DockPanel>
            </Border>

            <!-- Recent Pages (internal scroll) -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Recent Pages"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,0,0,14" />

                    <TextBlock DockPanel.Dock="Top"
                               Text="No pages opened yet. Pick a tool to get started."
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding NoRecentPages, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
								  Margin="8,0,0,0" Padding="0,0,8,0"
                                  Visibility="{Binding HasRecentPages, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding RecentPages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ctrl:QuickAccessTile Margin="0,0,0,8"
                                                          Glyph="{Binding Glyph}"
                                                          Title="{Binding Title}"
                                                          Target="{Binding Title}"
                                                          Click="RecentPage_Click" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- This PC (internal scroll) -->
            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Click="RefreshSpecsButton_Click"
                                ToolTip="Refresh machine info"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE72C;" FontSize="13" Margin="0,0,6,0" />
                                <TextBlock Text="Refresh" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="This PC"
                                   Style="{StaticResource SectionTitleStyle}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="OS" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,12" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MachineInfo.WindowsVersion}" Style="{StaticResource SpecValueStyle}" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,12" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MachineInfo.CpuName}" Style="{StaticResource SpecValueStyle}" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="GPU" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,12" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MachineInfo.GpuName}" Style="{StaticResource SpecValueStyle}" Margin="0,0,0,12" />

                            <!-- Memory + usage bar -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Memory" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MachineInfo.RamDisplay}" Style="{StaticResource SpecValueStyle}" Margin="0,0,0,4" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,12">
                                <ProgressBar Height="6"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding MachineInfo.RamUsagePercent}"
                                             Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
                                <TextBlock Text="{Binding MachineInfo.RamUsagePercentText}"
                                           FontSize="11" Margin="0,4,0,0"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>

                            <!-- Storage + usage bar -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Storage" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding MachineInfo.DiskDisplay}" Style="{StaticResource SpecValueStyle}" Margin="0,0,0,4" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,0,0,12">
                                <ProgressBar Height="6"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding MachineInfo.DiskUsedPercent}"
                                             Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
                                <TextBlock Text="{Binding MachineInfo.DiskUsedPercentText}"
                                           FontSize="11" Margin="0,4,0,0"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="App" Style="{StaticResource SpecLabelStyle}" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding AppVersion}" Style="{StaticResource SpecValueStyle}" />
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</local:PageBase>
