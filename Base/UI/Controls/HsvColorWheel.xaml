<UserControl x:Class="Base.UI.Controls.HsvColorWheel"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 mc:Ignorable="d"
			 d:DesignHeight="240" d:DesignWidth="240"
			 MinWidth="120" MinHeight="120">
	<!-- All layout/positioning is done in code-behind against this Canvas. -->
	<Canvas x:Name="Root"
			Background="Transparent"
			ClipToBounds="True"
			SizeChanged="Root_SizeChanged"
			MouseLeftButtonDown="Root_MouseLeftButtonDown"
			MouseMove="Root_MouseMove"
			MouseLeftButtonUp="Root_MouseLeftButtonUp">

		<Image x:Name="HueRingImage" Stretch="Fill"/>
		<Image x:Name="SvSquareImage" Stretch="Fill"/>

		<!-- Selection thumbs (drawn above the images, don't intercept the mouse). -->
		<Ellipse x:Name="HueThumb" Width="14" Height="14"
				 Stroke="White" StrokeThickness="2" Fill="#20000000"
				 IsHitTestVisible="False"/>
		<Ellipse x:Name="SvThumb" Width="14" Height="14"
				 Stroke="White" StrokeThickness="2" Fill="Transparent"
				 IsHitTestVisible="False"/>
	</Canvas>
</UserControl>
