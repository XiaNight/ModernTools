<UserControl x:Class="Base.UI.Controls.ColorPicker"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:Base.UI.Controls"
			 xmlns:ui="http://schemas.modernwpf.com/2019"
			 mc:Ignorable="d"
			 d:DesignWidth="300" d:DesignHeight="440">
	<Grid Margin="8">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Hue/saturation disc + vertical value slider -->
		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Canvas x:Name="DiscRoot" Grid.Column="0" Width="160" Height="160"
					Background="Transparent"
					SizeChanged="Disc_SizeChanged"
					MouseLeftButtonDown="Disc_Down"
					MouseMove="Disc_Move"
					MouseLeftButtonUp="Disc_Up">
				<Image x:Name="DiscImage" Stretch="Fill"/>
				<Ellipse x:Name="DiscThumb" Width="14" Height="14"
						 Stroke="White" StrokeThickness="2" Fill="Transparent"
						 IsHitTestVisible="False"/>
			</Canvas>

			<Canvas x:Name="ValueRoot" Grid.Column="1" Width="28" Height="160" Margin="12,0,0,0"
					Background="Transparent"
					SizeChanged="Value_SizeChanged"
					MouseLeftButtonDown="Value_Down"
					MouseMove="Value_Move"
					MouseLeftButtonUp="Value_Up">
				<Border x:Name="ValueBar" Width="18" Canvas.Left="5" Canvas.Top="0"
						CornerRadius="4" BorderThickness="1" BorderBrush="#40000000"/>
				<Border x:Name="ValueThumb" Width="26" Height="6" Canvas.Left="1"
						CornerRadius="3" Background="Transparent"
						BorderBrush="White" BorderThickness="2"
						IsHitTestVisible="False"/>
			</Canvas>
		</Grid>

		<!-- Mode buttons (not tabs): two toggle buttons side by side -->
		<Grid Grid.Row="1" Margin="36,10,36,0" HorizontalAlignment="Stretch">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<ToggleButton x:Name="RgbModeButton" HorizontalAlignment="Stretch" Grid.Column="0" Content="RGB" Click="RgbMode_Click"/>
			<ToggleButton x:Name="HsvModeButton" HorizontalAlignment="Stretch" Grid.Column="1" Content="HSV" Margin="6,0,0,0" Click="HsvMode_Click"/>
		</Grid>

		<!-- RGB and HSV panels share the same row; only one is visible at a time -->
		<Grid x:Name="RgbPanel" Grid.Row="2" Margin="0,6,0,0" Visibility="Collapsed">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="20"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="50"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="36"/>
				<RowDefinition Height="36"/>
				<RowDefinition Height="36"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="R" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			<local:GradientSlider x:Name="RSlider" Grid.Column="1" Grid.Row="0" Height="18" Minimum="0" Maximum="255"
									Margin="4,0" VerticalAlignment="Center" ValueChanged="RgbSliders_Changed"/>
			<TextBox x:Name="RBox" Grid.Column="2" Grid.Row="0" TextAlignment="Center" Height="32"
						 LostFocus="RgbBoxes_Commit" KeyDown="Box_KeyDown" MinWidth="40" d:Text="255"
						 ui:TextBoxHelper.IsDeleteButtonVisible="False"/>

			<TextBlock Text="G" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			<local:GradientSlider x:Name="GSlider" Grid.Column="1" Grid.Row="1" Height="18" Minimum="0" Maximum="255"
									Margin="4,0" VerticalAlignment="Center" ValueChanged="RgbSliders_Changed"/>
			<TextBox x:Name="GBox" Grid.Column="2" Grid.Row="1" TextAlignment="Center" Height="32"
						 LostFocus="RgbBoxes_Commit" KeyDown="Box_KeyDown" MinWidth="40" d:Text="255"
						 ui:TextBoxHelper.IsDeleteButtonVisible="False"/>

			<TextBlock Text="B" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			<local:GradientSlider x:Name="BSlider" Grid.Column="1" Grid.Row="2" Height="18" Minimum="0" Maximum="255"
									Margin="4,0" VerticalAlignment="Center" ValueChanged="RgbSliders_Changed"/>
			<TextBox x:Name="BBox" Grid.Column="2" Grid.Row="2" TextAlignment="Center" Height="32"
						 LostFocus="RgbBoxes_Commit" KeyDown="Box_KeyDown" MinWidth="40" d:Text="255"
						 ui:TextBoxHelper.IsDeleteButtonVisible="False"/>
		</Grid>

		<Grid x:Name="HsvPanel" Grid.Row="2" Margin="0,6,0,0" Visibility="Visible">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="12"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="50"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="36"/>
				<RowDefinition Height="36"/>
				<RowDefinition Height="36"/>
			</Grid.RowDefinitions>

			<TextBlock Text="H" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
			<local:GradientSlider x:Name="HSlider" Grid.Column="1" Grid.Row="0" Height="18" Minimum="0" Maximum="360"
									Margin="4,0" VerticalAlignment="Center" ValueChanged="HsvSliders_Changed"/>
			<TextBox x:Name="HBox" Grid.Column="2" Grid.Row="0" TextAlignment="Center" Height="32"
						 LostFocus="HsvBoxes_Commit" KeyDown="Box_KeyDown" MinWidth="40" d:Text="255"
						 ui:TextBoxHelper.IsDeleteButtonVisible="False"/>

			<TextBlock Text="S" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left"/>
			<local:GradientSlider x:Name="SSlider" Grid.Column="1" Grid.Row="1" Height="18" Minimum="0" Maximum="100"
									Margin="4,0" VerticalAlignment="Center" ValueChanged="HsvSliders_Changed"/>
			<TextBox x:Name="SBox" Grid.Column="2" Grid.Row="1" TextAlignment="Center" Height="32"
						 LostFocus="HsvBoxes_Commit" KeyDown="Box_KeyDown" MinWidth="40" d:Text="255"
						 ui:TextBoxHelper.IsDeleteButtonVisible="False"/>

			<TextBlock Text="V" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Left"/>
			<local:GradientSlider x:Name="VSlider" Grid.Column="1" Grid.Row="2" Height="18" Minimum="0" Maximum="100"
									Margin="4,0" VerticalAlignment="Center" ValueChanged="HsvSliders_Changed"/>
			<TextBox x:Name="VBox" Grid.Column="2" Grid.Row="2" TextAlignment="Center" Height="32"
						 LostFocus="HsvBoxes_Commit" KeyDown="Box_KeyDown" MinWidth="40" d:Text="255"
						 ui:TextBoxHelper.IsDeleteButtonVisible="False"/>
		</Grid>
		
		<!-- Editable HEX -->
		<Grid Grid.Row="3">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<TextBlock Text="HEX" VerticalAlignment="Center" Margin="0,0,8,0"/>
			<TextBox x:Name="HexBox" Grid.Column="1"
					 LostFocus="Hex_Commit" KeyDown="Box_KeyDown"
					 ui:TextBoxHelper.IsDeleteButtonVisible="False"/>
		</Grid>
	</Grid>
</UserControl>
