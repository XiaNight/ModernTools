<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Categorical accent brushes (charts, meters, audio channels).
	     All other surface/text/background theming comes from ModernWPF's theme
	     resources (SystemControl* / TextFillColor* / ApplicationPageBackground*). -->
	<SolidColorBrush x:Key="Accent1Brush" Color="CornflowerBlue"/>
	<SolidColorBrush x:Key="Accent2Brush" Color="DarkOrange"/>
	<SolidColorBrush x:Key="Accent3Brush" Color="LawnGreen"/>
	<SolidColorBrush x:Key="Accent4Brush" Color="OrangeRed"/>
</ResourceDictionary>
