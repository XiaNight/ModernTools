<UserControl x:Class="Base.Components.ConfigDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Base.Components"
             xmlns:mtc="clr-namespace:Base.Components"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <ui:ContentDialog x:Name="Dialog">
            <Grid MinWidth="360" Margin="0,-12,0,0" d:Height="600">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,4,0,0">
                    <TextBlock Text="Config" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                    <TextBlock x:Name="PageNameText" Text="Subtitle" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,16,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ConfigContainer" Margin="0,4,18,0">
                        <TextBlock x:Name="EmptyPlaceholder"
                                   Text="There are no configurable options available."
                                   Opacity="0.7"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <!-- Design-time only preview of every editor type. Collapsed at runtime
                             (and cleared by Build()); shown only in the XAML designer. -->
                        <StackPanel Visibility="Collapsed" d:Visibility="Visible">
                            <mtc:ConfigHeader d:Text="Header"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Text / Number" FontSize="14" VerticalAlignment="Center"/>
                                <mtc:ConfigInputField Grid.Column="1"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Slider" FontSize="14" VerticalAlignment="Center"/>
                                <mtc:ConfigSlider Grid.Column="1"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Toggle" FontSize="14" VerticalAlignment="Center"/>
                                <mtc:ConfigToggle Grid.Column="1"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Enum" FontSize="14" VerticalAlignment="Center"/>
                                <mtc:ConfigEnumField Grid.Column="1"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="DateTime" FontSize="14" VerticalAlignment="Center"/>
                                <mtc:ConfigDateTimeField Grid.Column="1"/>
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TimeSpan" FontSize="14" VerticalAlignment="Center"/>
                                <mtc:ConfigTimeSpanField Grid.Column="1"/>
                            </Grid>

                            <mtc:ConfigHelpBox d:Text="This is a help box shown beneath a field."/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2"
                        x:Name="CloseButton"
                        Content="Close"
                        MinWidth="90"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0"
                        Click="CloseButton_Click"/>
            </Grid>
        </ui:ContentDialog>
    </Grid>
</UserControl>
