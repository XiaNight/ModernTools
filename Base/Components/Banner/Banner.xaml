<UserControl x:Class="Base.Components.Banner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Base.Components"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignHeight="24" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Banner severity backgrounds (self-contained; not part of the shared brush set). -->
        <SolidColorBrush x:Key="InfoBackgroundBrush" Color="#663399ff"/>
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#66ffcc00"/>
        <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#66ff3b30"/>
    </UserControl.Resources>
    <Border x:Name="RootBorder" Background="{DynamicResource WarningBackgroundBrush}" MinHeight="24">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:FontIcon x:Name="SeverityIcon" Grid.Column="0"
                         Glyph="&#xE7BA;" FontSize="14" Margin="8,2,6,2"
                         VerticalAlignment="Center"
                         FontFamily="Segoe Fluent Icons"/>

            <TextBlock x:Name="MessageText" Grid.Column="1"
                       FontSize="12" FontWeight="Normal"
                       Text="Banner"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="0,3,8,3"/>

            <Button x:Name="CloseButton" Grid.Column="2"
                    Width="24" Height="24" Padding="0"
                    Margin="0,0,4,0"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" ToolTip="Dismiss"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    Click="CloseButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#22000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <ui:FontIcon x:Name="CloseIcon" Glyph="&#xE711;" FontSize="12"
                             FontFamily="Segoe Fluent Icons"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
